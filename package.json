{
  "name": "tanvite",
  "license": "MIT",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "routes:generate": "node ./scripts/generate-routes.mjs",
    "openapi:check": "node ./scripts/openapi-check.mjs",
    "openapi:generate": "node ./scripts/openapi-generate.mjs",
    "openapi:mock": "node ./scripts/openapi-mock.mjs",
    "dev": "vite",
    "dev:mock": "cross-env VITE_API_MOCK=msw vite",
    "build": "pnpm routes:generate && tsc -b && vite build",
    "build:pages": "pnpm routes:generate && tsc -b && vite build --mode pages && node ./scripts/postbuild-pages.mjs dist-pages",
    "preview": "vite preview --port 4419 --strictPort",
    "preview:pages": "vite preview --outDir dist-pages --port 4419 --strictPort",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-query-devtools": "^5.56.0",
    "@tanstack/react-router": "^1.56.0",
    "@tanstack/router-devtools": "^1.56.0",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.427.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.47.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@tanstack/router-generator": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "husky": "^9.1.5",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.2.10",
    "msw": "^2.12.10",
    "orval": "^6.31.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.1.0",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}